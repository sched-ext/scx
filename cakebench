    exit 1
fi

export SCX_REPO_ROOT

if [[ "$#" -gt 0 ]]; then
    case "$1" in
        debug-one|diag-one|debug_one|diag_one)
            shift
            run_debug_one "$@"
            exit $?
            ;;
        one|single)
            if has_arg --debug "$@"; then
                shift
                run_debug_one "$@"
                exit $?
            fi
            ;;
        --bench)
            shift
            [[ "$#" -gt 0 ]] || {
                usage >&2
                echo "error: --bench requires a preset" >&2
                exit 1
            }
            expand_bench_preset "$@"
            ;;
        --bench=*)
            preset="${1#*=}"
            shift
            expand_bench_preset "${preset}" "$@"
            ;;
        -h|--help|help)
            usage
            echo
            exec "${BENCH_LAUNCHER}" --help
            ;;
    esac
fi

exec "${BENCH_LAUNCHER}" "$@"
